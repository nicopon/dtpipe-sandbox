# =============================================================================
# Competitive Benchmark: dtpipe vs Meltano vs Sling
# Benchmark parameters and DB connections configuration
# =============================================================================

# --- Dataset Parameters ---
# Number of rows for benchmark datasets (2 million by default)
BENCHMARK_ROWS=2000000

# Number of repetitions per benchmark (3 by default)
BENCHMARK_REPETITIONS=3

# --- Docker Network ---
BENCHMARK_NETWORK=benchmark-net

# --- PostgreSQL Configuration ---
DB_POSTGRES_HOST=${DB_POSTGRES_HOST:-dtpipe-integ-postgres}
DB_POSTGRES_PORT=${DB_POSTGRES_PORT:-5432}
DB_POSTGRES_DB=${DB_POSTGRES_DB:-integration}
DB_POSTGRES_USER=${DB_POSTGRES_USER:-postgres}
DB_POSTGRES_PASSWORD=${DB_POSTGRES_PASSWORD:-password}

# --- SQL Server (Azure SQL Edge) Configuration ---
DB_MSSQL_HOST=${DB_MSSQL_HOST:-dtpipe-integ-mssql}
DB_MSSQL_PORT=${DB_MSSQL_PORT:-1433}
DB_MSSQL_DB=${DB_MSSQL_DB:-master}
DB_MSSQL_USER=${DB_MSSQL_USER:-sa}
DB_MSSQL_PASSWORD=${DB_MSSQL_PASSWORD:-Password123!}

# --- Oracle Configuration ---
DB_ORACLE_HOST=${DB_ORACLE_HOST:-dtpipe-integ-oracle}
DB_ORACLE_PORT=${DB_ORACLE_PORT:-1521}
DB_ORACLE_SID=${DB_ORACLE_SID:-FREEPDB1}
DB_ORACLE_SERVICE=${DB_ORACLE_SERVICE:-FREEPDB1}
DB_ORACLE_USER=${DB_ORACLE_USER:-testuser}
DB_ORACLE_PASSWORD=${DB_ORACLE_PASSWORD:-password}

# --- Benchmark Names (for filtering) ---
# Options: all, B01, B02, B03, B04, B05, B06, dtpipe, meltano, sling
BENCHMARK_SCOPE=${BENCHMARK_SCOPE:-all}
BENCHMARK_TOOL=${BENCHMARK_TOOL:-all}